{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDbSettings": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "quan4_culinary_tourism"
  },
  "JwtSettings": {
    "SecretKey": "__SET_JWT_SECRET_IN_ENVIRONMENT__",
    "Issuer": "Quan4CulinaryTourism.Api",
    "Audience": "Quan4CulinaryTourism.Client",
    "ExpireMinutes": 120
  },
  "UploadSettings": {
    "UploadPath": "wwwroot/uploads",
    "MaxImageSizeMb": 5,
    "MaxAudioSizeMb": 20
  },
  "DefaultAdmin": {
    "Email": "admin@quan4tourism.local",
    "Password": "",
    "FullName": "System Admin"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "http://localhost:5174"
    ]
  }
}
