# Template only.
# The API now auto-loads `.env` from the backend project root if present.
# Real environment variables from the host/server still override values in this file.
ASPNETCORE_ENVIRONMENT=Production
JwtSettings__SecretKey=replace-with-a-long-random-secret
DefaultAdmin__Email=admin@example.com
DefaultAdmin__Password=replace-with-a-strong-password
TextToSpeechSettings__Enabled=true
TextToSpeechSettings__PythonCommand=python
TextToSpeechSettings__DefaultVoice=vi
CloudinarySettings__CloudName=
CloudinarySettings__ApiKey=
CloudinarySettings__ApiSecret=
CloudinarySettings__RootFolder=quan4-culinary-tourism
AI_ENABLED=false
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=30
PublicSiteSettings__BaseUrl=https://your-public-site.example.com
Cors__AllowedOrigins__0=https://your-admin.example.com
Cors__AllowedOrigins__1=https://your-public-site.example.com
