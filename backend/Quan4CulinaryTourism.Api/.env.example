# Template only.
# Copy to `backend/Quan4CulinaryTourism.Api/.env` for local `dotnet run`
# or for `docker compose up --build` from the repo root.
# Real environment variables from the host/server still override values in this file.
JwtSettings__SecretKey=dev-local-jwt-secret-please-change-before-sharing-1234567890
DefaultAdmin__Email=admin@quan4tourism.local
DefaultAdmin__Password=Admin@123456
DatabaseResetSettings__Enabled=false
DatabaseResetSettings__Token=
TextToSpeechSettings__Enabled=true
TextToSpeechSettings__PythonCommand=python
TextToSpeechSettings__DefaultVoice=vi
CloudinarySettings__CloudName=
CloudinarySettings__ApiKey=
CloudinarySettings__ApiSecret=
CloudinarySettings__RootFolder=quan4-culinary-tourism
AI_ENABLED=false
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=30
PublicSiteSettings__BaseUrl=http://localhost:5174
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://localhost:5174
