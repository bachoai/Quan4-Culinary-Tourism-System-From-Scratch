{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDbSettings": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "quan4_culinary_tourism"
  },
  "DatabaseResetSettings": {
    "Enabled": false,
    "Token": "",
    "MarkerCollectionName": "__deployment_resets"
  },
  "JwtSettings": {
    "SecretKey": "__SET_JWT_SECRET_IN_ENVIRONMENT__",
    "Issuer": "Quan4CulinaryTourism.Api",
    "Audience": "Quan4CulinaryTourism.Client",
    "ExpireMinutes": 120
  },
  "UploadSettings": {
    "UploadPath": "wwwroot/uploads",
    "MaxImageSizeMb": 5,
    "MaxAudioSizeMb": 20
  },
  "CloudinarySettings": {
    "CloudName": "",
    "ApiKey": "",
    "ApiSecret": "",
    "RootFolder": "quan4-culinary-tourism"
  },
  "TextToSpeechSettings": {
    "Enabled": true,
    "PythonCommand": "python",
    "ScriptPath": "tools/tts_generate.py",
    "DefaultVoice": "vi",
    "Rate": "+0%",
    "TimeoutSeconds": 90
  },
  "PublicSiteSettings": {
    "BaseUrl": "http://localhost:5174"
  },
  "Ai": {
    "Enabled": false,
    "Provider": "OpenAICompatible",
    "BaseUrl": "https://api.openai.com/v1",
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "TimeoutSeconds": 30
  },
  "DefaultAdmin": {
    "Email": "admin@quan4tourism.local",
    "Password": "",
    "FullName": "System Admin"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "http://localhost:3000",
      "http://localhost:5174",
      "http://127.0.0.1:5174"
    ]
  }
}
